  "scripts": {
    "dev": "node scripts/dev-runner.js",
    "dev:stop": "powershell -NoProfile -Command \"Get-NetTCPConnection -LocalPort 3000,3001 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; Write-Host 'Dev servers stopped.'\"",
    "dev:next": "next dev",
    "dev:ws": "node scripts/chat-ws-server.js",
