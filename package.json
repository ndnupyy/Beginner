    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "better-sqlite3": "^12.11.1",
    "isomorphic-dompurify": "^3.18.0",
    "next": "16.2.9",
