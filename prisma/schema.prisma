generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model articles {
  id            String @id
  title         String
  content       String
  summary       String @default("")
  tags          String @default("[]")
  thumbnail_url String @default("")
  category      String @default("")
  article_type  String @default("原创")
  visibility    String @default("全部可见")
  author_name   String @default("博客作者")
  author_avatar String @default("/default-avatar.svg")
  views         Int    @default(0)
  created_at    String
  updated_at    String
  author_id     String?

}

model users {
  id                  String @id
  username            String  @unique(map: "sqlite_autoindex_users_2")
  email               String  @unique(map: "sqlite_autoindex_users_3")
  password_hash       String
  avatar_url          String? @default("/default-avatar.svg")
  reset_token         String?
  reset_token_expires String?
  created_at          String
  updated_at          String
}
